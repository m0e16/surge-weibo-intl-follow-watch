{
  "id": "weibo.followwatch.sub",
  "name": "微博关注黑名单检测",
  "author": "@m0e16",
  "icon": "https://raw.githubusercontent.com/Orz-3/mini/master/Color/Weibo.png",
  "repo": "https://github.com/m0e16/surge-weibo-intl-follow-watch",
  "apps": [
    {
      "id": "weibo.followwatch",
      "name": "微博关注黑名单检测",
      "desc_html": "<p>进入微博国际版用户主页时，按 UID 检测其可见关注是否命中黑名单。</p><p>每行只填写一个微博 UID；命中时自动显示接口返回的当前昵称。</p>",
      "keys": [
        "weibo.followwatch.blacklist"
      ],
      "settings": [
        {
          "id": "weibo.followwatch.blacklist",
          "name": "黑名单",
          "val": "",
          "type": "textarea",
          "placeholder": "1234567890\n2345678901",
          "autoGrow": true,
          "rows": 12,
          "desc": "每行一个 UID；其他内容将被忽略。"
        }
      ],
      "author": "@m0e16",
      "repo": "https://github.com/m0e16/surge-weibo-intl-follow-watch",
      "script": "https://raw.githubusercontent.com/m0e16/surge-weibo-intl-follow-watch/main/scripts/boxjs_normalize.js",
      "icons": [
        "https://raw.githubusercontent.com/Orz-3/mini/master/Alpha/Weibo.png",
        "https://raw.githubusercontent.com/Orz-3/mini/master/Color/Weibo.png"
      ],
      "scripts": [
        {
          "name": "校验并规范化名单",
          "script": "https://raw.githubusercontent.com/m0e16/surge-weibo-intl-follow-watch/main/scripts/boxjs_normalize.js"
        },
        {
          "name": "清理检测缓存",
          "script": "https://raw.githubusercontent.com/m0e16/surge-weibo-intl-follow-watch/main/scripts/boxjs_clear_cache.js"
        }
      ]
    }
  ]
}
